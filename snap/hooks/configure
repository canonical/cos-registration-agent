#!/bin/sh -e

# Setup logging
log_msg() {
    logger -t "${SNAP_NAME}.configure" "$1"
}

log_msg "=== Configure hook called ==="
log_msg "SNAP_COMMON: ${SNAP_COMMON}"
log_msg "SNAP: ${SNAP}"

# In confdb-first architecture, configuration comes from confdb views
# The configure hook is intentionally minimal - configuration is managed
# through confdb views and the registration-daemon handles registration
log_msg "Configure hook - no action needed (confdb-first architecture)"

log_msg "Configure hook completed successfully"
log_msg "========================================"
log_msg ""
