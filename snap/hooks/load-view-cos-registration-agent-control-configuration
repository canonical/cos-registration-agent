#!/usr/bin/env python3

import os
import subprocess
import sys
from datetime import datetime

def log(message):
    """Log message to journalctl."""
    snap_name = os.environ.get("SNAP_NAME", "cos-registration-agent")
    try:
        subprocess.run(
            ["logger", "-t", f"{snap_name}.load-view", message],
            check=False
        )
    except Exception:
        pass

# Path to the device configuration file
config_file = os.path.join(os.environ.get("SNAP_COMMON", ""), "device.yaml")

log(f"=== Load-view hook called at {datetime.now()} ===")

# Check if file exists
if not os.path.exists(config_file):
    log(f"ERROR: Configuration file {config_file} not found")
    print(f"ERROR: Configuration file {config_file} not found", file=sys.stderr)
    sys.exit(1)

try:
    # Read YAML file
    with open(config_file, 'r') as f:
        config_data = f.read()
    
    # Set the YAML string into confdb
    subprocess.run(
        ["snapctl", "set", "--view", ":cos-registration-agent-control-configuration", f"data={config_data}"],
        check=True,
        capture_output=True,
        text=True
    )
    
except Exception as e:
    log(f"ERROR: Failed to load configuration: {e}")
    print(f"ERROR: Failed to load configuration: {e}", file=sys.stderr)
    sys.exit(1)
