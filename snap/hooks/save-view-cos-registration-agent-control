#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from datetime import datetime

def log(message):
    """Log message to journalctl."""
    snap_name = os.environ.get("SNAP_NAME", "cos-registration-agent")
    try:
        subprocess.run(
            ["logger", "-t", f"{snap_name}.save-view", message],
            check=False
        )
    except Exception:
        pass

# Path to the device configuration file
config_file = os.path.join(os.environ.get("SNAP_COMMON", ""), "device.yaml")

log(f"=== Save-view hook called at {datetime.now()} ===")

try:
    # Get the YAML string from confdb
    result = subprocess.run(
        ["snapctl", "get", "--view", ":cos-registration-agent-control", "data"],
        capture_output=True,
        text=True,
        check=True
    )
    
    config_data = result.stdout.strip()
    
    if not config_data:
        log("WARNING: No configuration data found in confdb")
        sys.exit(0)
    
    # Write YAML string to file
    with open(config_file, 'w') as f:
        f.write(config_data)
    
except subprocess.CalledProcessError as e:
    log(f"ERROR: Failed to read from confdb: {e.stderr}")
    print(f"ERROR: Failed to read from confdb: {e.stderr}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    log(f"ERROR: Failed to save configuration: {e}")
    print(f"ERROR: Failed to save configuration: {e}", file=sys.stderr)
    sys.exit(1)

